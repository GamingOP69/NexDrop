# App
NODE_ENV=production
APP_URL=http://localhost:3000
# Optional: set this to 1 in production runtimes to enable strict env validation.
NEXDROP_RUNTIME=1

# Database / cache
DATABASE_URL=postgresql://nexdrop:nexdrop-secret@localhost:5432/nexdrop?schema=public
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=replace-with-long-random-string-access
JWT_REFRESH_SECRET=replace-with-long-random-string-refresh
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# Email / SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASS=replace-me
EMAIL_FROM="NexDrop <noreply@example.com>"

# Storage
STORAGE_PATH=./storage
TEMP_UPLOAD_PATH=./storage/tmp
MAX_FILE_SIZE=10737418240
CHUNK_SIZE=5242880

# S3 / object storage (optional)
S3_ENABLED=false
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# Sentry / observability (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Email queue
EMAIL_QUEUE_ENABLED=false
EMAIL_QUEUE_RETRIES=3

# Admin
ADMIN_EMAILS=admin@example.com,owner@example.com

# Seed data helpers
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123456

# Certbot / HTTPS automation
DOMAIN=yourdomain.com
DOMAIN_WWW=www.yourdomain.com
LETSENCRYPT_EMAIL=admin@example.com

# Optional public ad client
NEXT_PUBLIC_ADSENSE_CLIENT=
